GITLAB_URL=http://172.18.20.5
RUNNER_REGISTRATION_TOKEN=replace-me
RUNNER_EXECUTOR=docker
BUILDER_IMAGE_FAMILY=tf-particles/devops/cuda-builder:cuda11.7-cmake3.26
BUILDER_DEFAULT_PLATFORM=centos7
BUILDER_PLATFORMS=centos7,rocky8,ubuntu2204
RUNNER_DOCKER_IMAGE=tf-particles/devops/cuda-builder:cuda11.7-cmake3.26-centos7
RUNNER_SERVICE_IMAGE=gitlab/gitlab-runner:alpine-v16.10.1
RUNNER_DESCRIPTION_PREFIX=shared-gpu
RUNNER_TAG_LIST=gpu,cuda,cuda-11
RUNNER_MULTI_TAG_LIST=gpu-multi,cuda,cuda-11
RUNNER_LOCKED=false
RUNNER_RUN_UNTAGGED=false
RUNNER_ACCESS_LEVEL=not_protected
RUNNER_GPU_CONCURRENCY=2
RUNNER_MULTI_GPU_CONCURRENCY=1
RUNNER_CACHE_DIR=./runner/cache
RUNNER_CONFIG_DIR=./runner/config
BUILDER_IMAGE=tf-particles/devops/cuda-builder:cuda11.7-cmake3.26-centos7
IMAGE_ARCHIVE_PATH=artifacts/offline-images.tar.gz

# Build the current project root mounted at /workspace.
CUDA_CXX_PROJECT_DIR=.
CUDA_CXX_BUILD_ROOT=./artifacts/cuda-cxx-build
CUDA_CXX_CMAKE_GENERATOR=Ninja

# Example custom CMake configure flags:
# - use Release build type
# - set a specific CUDA architecture
# - emit compile_commands.json
CUDA_CXX_CMAKE_ARGS=-DCMAKE_BUILD_TYPE=Release -DCMAKE_CUDA_ARCHITECTURES=75 -DCMAKE_EXPORT_COMPILE_COMMANDS=ON

# Example custom build flags:
# - parallel build
# - verbose output
CUDA_CXX_BUILD_ARGS=--parallel 8 --verbose
