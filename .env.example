# Published builder image family prefix.
# Per-platform tags are derived as:
#   ${BUILDER_IMAGE_FAMILY}:${BUILDER_DEFAULT_PLATFORM}-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:rocky8-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:rocky9-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:ubuntu2204-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:ubuntu2404-${BUILDER_CUDA_VERSION}
BUILDER_CUDA_VERSION=12.9.1
BUILDER_IMAGE_FAMILY=tf-particles/devops/cuda-builder
BUILDER_IMAGE=tf-particles/devops/cuda-builder:ubuntu2404-12.9.1

# Default platform used by build scripts when no explicit --platform is given.
BUILDER_DEFAULT_PLATFORM=ubuntu2404

# Optional per-platform CUDA version map for mixed support windows.
BUILDER_PLATFORM_CUDA_VERSIONS=centos7=12.4.0,rocky8=12.9.1,rocky9=12.9.1,ubuntu2204=12.9.1,ubuntu2404=12.9.1

# Comma-separated platform matrix used by the builder image build script.
BUILDER_PLATFORMS=centos7,rocky8,rocky9,ubuntu2204,ubuntu2404
