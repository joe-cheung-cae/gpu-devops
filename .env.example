GITLAB_URL=https://gitlab.example.com/
RUNNER_REGISTRATION_TOKEN=replace-me
RUNNER_EXECUTOR=docker
RUNNER_DOCKER_IMAGE=registry.example.com/devops/cuda-builder:cuda12.4-cmake3.30-ubuntu22.04
RUNNER_DESCRIPTION_PREFIX=shared-gpu
RUNNER_TAG_LIST=gpu,cuda,cuda-12
RUNNER_MULTI_TAG_LIST=gpu-multi,cuda,cuda-12
RUNNER_LOCKED=false
RUNNER_RUN_UNTAGGED=false
RUNNER_ACCESS_LEVEL=not_protected
RUNNER_GPU_CONCURRENCY=2
RUNNER_MULTI_GPU_CONCURRENCY=1
RUNNER_CACHE_DIR=./runner/cache
RUNNER_CONFIG_DIR=./runner/config
BUILDER_IMAGE=registry.example.com/devops/cuda-builder:cuda12.4-cmake3.30-ubuntu22.04
