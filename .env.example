# Published builder image family prefix.
# Per-platform tags are derived as:
#   ${BUILDER_IMAGE_FAMILY}:${BUILDER_DEFAULT_PLATFORM}-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:rocky8-${BUILDER_CUDA_VERSION}
#   ${BUILDER_IMAGE_FAMILY}:ubuntu2204-${BUILDER_CUDA_VERSION}
BUILDER_CUDA_VERSION=11.7.1
BUILDER_IMAGE_FAMILY=tf-particles/devops/cuda-builder
BUILDER_IMAGE=tf-particles/devops/cuda-builder:centos7-11.7.1

# Default platform used by build scripts when no explicit --platform is given.
BUILDER_DEFAULT_PLATFORM=centos7

# Comma-separated platform matrix used by the builder image build script.
BUILDER_PLATFORMS=centos7,rocky8,ubuntu2204
