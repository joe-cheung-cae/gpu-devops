# Published builder image family.
# Per-platform tags are derived as:
#   ${BUILDER_IMAGE_FAMILY}-centos7
#   ${BUILDER_IMAGE_FAMILY}-rocky8
#   ${BUILDER_IMAGE_FAMILY}-ubuntu2204
BUILDER_IMAGE_FAMILY=tf-particles/devops/cuda-builder:cuda11.7-cmake3.26

# Default platform used by build scripts when no explicit --platform is given.
BUILDER_DEFAULT_PLATFORM=centos7

# Comma-separated platform matrix used by build/export scripts.
BUILDER_PLATFORMS=centos7,rocky8,ubuntu2204

# Default builder image tag used by scripts that expect one concrete image.
# Usually this should match ${BUILDER_IMAGE_FAMILY}-${BUILDER_DEFAULT_PLATFORM}.
BUILDER_IMAGE=tf-particles/devops/cuda-builder:cuda11.7-cmake3.26-centos7

# Offline image archive path produced by scripts/export/images.sh / consumed by scripts/import/images.sh.
IMAGE_ARCHIVE_PATH=artifacts/offline-images.tar.gz

# Local CUDA/C++ compose workflow settings.
# Optional host project root mounted to /workspace.
# Keep this machine-specific path in your local .env only.
# Example: HOST_PROJECT_DIR=/path/to/your/project
HOST_PROJECT_DIR=.

# These paths are resolved inside the mounted /workspace tree.
# Use "." to build the target project root, or a subdirectory under that root.
CUDA_CXX_PROJECT_DIR=./examples/cuda-smoke

# Build output root under /workspace.
CUDA_CXX_BUILD_ROOT=./artifacts/cuda-cxx-build

# Install output root under /workspace.
CUDA_CXX_INSTALL_ROOT=./artifacts/cuda-cxx-install

# Project-local dependency cache root under /workspace.
CUDA_CXX_DEPS_ROOT=./artifacts/deps

# CMake generator used by docker-compose.yml local builds.
CUDA_CXX_CMAKE_GENERATOR=Ninja

# Extra flags appended to "cmake -S ... -B ...".
# Example: -DCMAKE_BUILD_TYPE=Release -DCMAKE_CUDA_ARCHITECTURES=75
CUDA_CXX_CMAKE_ARGS=

# Extra flags appended to "cmake --build ...".
# Example: --parallel 8 --verbose
CUDA_CXX_BUILD_ARGS=
